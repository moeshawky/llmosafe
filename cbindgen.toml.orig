language = "C"
header = "/* LLMOSAFE: Safety-Critical AI Agent Library (C Bindings) */"
include_guard = "LLMOSAFE_H"
autogen_warning = "/* This file is automatically generated by cbindgen. Do not edit manually. */"
tab_width = 4
line_length = 100
pragma_once = true

[export]
include = ["Synapse"]

[fn]
rename_args = "snake_case"

[struct]
rename_fields = "snake_case"

[parse]
parse_deps = false

[defines]
"target_arch = \"x86_64\"" = "ARCH_X86_64"

[export.rename]
"u128" = "unsigned __int128"
